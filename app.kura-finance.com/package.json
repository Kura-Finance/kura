{
  "name": "kura-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "cert:gen": "bash ./scripts/generate-local-cert.sh",
    "build": "next build",
    "build:prod": "NODE_ENV=production next build",
    "build:static": "BUILD_MODE=export next build && du -sh out",
    "build:standalone": "BUILD_MODE=standalone next build && du -sh .next/standalone",
    "start": "next start",
    "start:standalone": "node .next/standalone/server.js",
    "deploy": "bash ./scripts/deploy.sh",
    "deploy:preview": "npm run build && firebase hosting:channel:deploy preview --project kura-b39eb",
    "deploy:static": "npm run build:static && firebase deploy --only hosting --project kura-b39eb",
    "deploy:cloud-run": "npm run build:standalone && gcloud run deploy kura-web --source . --project kura-b39eb --region us-central1 --allow-unauthenticated",
    "lint": "eslint"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.96.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@walletconnect/ethereum-provider": "^2.23.9",
    "@web3modal/wagmi": "^5.1.11",
    "firebase": "^12.11.0",
    "framer-motion": "^12.38.0",
    "jsonwebtoken": "^9.0.3",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.6.0",
    "react-plaid-link": "^4.1.1",
    "viem": "^2.47.10",
    "wagmi": "^3.6.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
